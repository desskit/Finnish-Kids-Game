{
  "name": "finnish-kids-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A playful PWA that teaches everyday Finnish to early readers.",
  "scripts": {
    "icons": "node scripts/make-icons.mjs",
