{
  "name": "finnish-kids-game",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A playful PWA that teaches everyday Finnish to early readers.",
  "scripts": {
    "icons": "node scripts/make-icons.mjs",
    "art:manifest": "node scripts/art-manifest.mjs",
    "audit:sentences": "vite-node scripts/audit-sentences.ts",
    "dev": "vite",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.node.json",
    "typecheck:test": "tsc -p tsconfig.vitest.json",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-node": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.1.9"
  }
}
